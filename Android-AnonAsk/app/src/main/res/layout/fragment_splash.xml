<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <!-- App Logo / 图标 -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/app_name"
            android:elevation="8dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <!-- App Name 渐变文字 -->
        <TextView
            android:id="@+id/splashAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:scaleX="0.3"
            android:scaleY="0.3"
            android:text="@string/app_name"
            android:textColor="#FF1F1A3A"
            android:textSize="36sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="12dp" />

        <!-- 副标题 -->
        <TextView
            android:id="@+id/splashTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            android:text="完全匿名的你问我答"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:maxWidth="300dp"
            android:textColor="#FF888888"
            android:textSize="14sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <!-- MD3 转圈圈 -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/splashSpinner"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:indeterminate="true"
            app:indicatorColor="@color/md_primary"
            app:trackThickness="3dp" />

    </LinearLayout>

</FrameLayout>
