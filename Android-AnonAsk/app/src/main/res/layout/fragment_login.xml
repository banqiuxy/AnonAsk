<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/nav_background"
        app:title=""
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- Logo + 标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/md_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/login_title"
                android:textColor="#FF888888"
                android:textSize="14sp" />

            <!-- 卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="2dp"
                app:contentPadding="24dp"
                app:strokeColor="@color/md_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Tab 切换 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/tab_background"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/tabLogin"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/tab_active"
                            android:gravity="center"
                            android:text="@string/tab_login"
                            android:textColor="@color/md_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tabRegister"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:background="@drawable/tab_inactive"
                            android:gravity="center"
                            android:text="@string/tab_register"
                            android:textColor="#FF666666"
                            android:textSize="15sp" />
                    </LinearLayout>

                    <!-- 错误消息 -->
                    <TextView
                        android:id="@+id/errorMsg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/error_red"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/errorMsg2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/error_red"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <!-- 联系方式选择 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/contact_label"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <TextView
                            android:id="@+id/contactPhone"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/contact_opt_active"
                            android:gravity="center"
                            android:text="@string/phone_label"
                            android:textColor="@color/md_primary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/contactQQ"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginHorizontal="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/contact_opt_inactive"
                            android:gravity="center"
                            android:text="@string/qq_label"
                            android:textColor="#FF666666"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/contactWechat"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/contact_opt_inactive"
                            android:gravity="center"
                            android:text="@string/wechat_label"
                            android:textColor="#FF666666"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- 联系方式输入 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/contactInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:hintEnabled="true"
                        app:counterEnabled="true"
                        app:counterMaxLength="100">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/contactValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/phone_hint"
                            android:inputType="text"
                            android:maxLength="100" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 密码输入 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/passwordInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:passwordToggleEnabled="true"
                        app:counterEnabled="true"
                        app:counterMaxLength="20">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/password_label"
                            android:inputType="textPassword"
                            android:maxLength="20" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/password_hint"
                        android:textColor="#FF888888"
                        android:textSize="12sp" />

                    <!-- 提交按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/submitBtn"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:text="@string/tab_login"
                        android:textSize="16sp" />

                    <!-- 切换提示 — 内容由 Java 代码动态设置 -->
                    <TextView
                        android:id="@+id/switchHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:textColor="#FF888888"
                        android:textSize="14sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
