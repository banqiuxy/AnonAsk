<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.banqiu.anonask.fragment.SplashFragment"
        android:label="AnonAsk"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_main"
            app:destination="@id/mainTabsFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/mainTabsFragment"
        android:name="com.banqiu.anonask.fragment.MainTabsFragment"
        android:label="AnonAsk"
        tools:layout="@layout/fragment_main_tabs">
        <action
            android:id="@+id/action_main_to_login"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.banqiu.anonask.fragment.LoginFragment"
        android:label="登录"
        tools:layout="@layout/fragment_login">
        <argument
            android:name="redirect_target_uid"
            app:argType="long"
            android:defaultValue="0L" />
    </fragment>

</navigation>
